{
  "name": "pulse-reader",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "RSS/Newsletter/PDF reader companion for Obsidian",
  "main": "electron/out/main.js",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "electron:compile": "node scripts/build-electron.mjs",
    "electron:dev": "npm run electron:compile && concurrently \"vite dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run electron:compile && vite build && electron-builder --publish never",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "pdfjs-dist": "^4.8.69",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "svelte": "^5.17.3",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.pulsereader.app",
    "productName": "PulseReader",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/out/**/*",
      "build/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
